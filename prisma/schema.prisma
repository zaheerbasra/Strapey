// Strapey - Centralized Commerce Management Platform
// Simple, local-first architecture with SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// PRODUCTS - Central Product Catalog
// ============================================
model Product {
  id          String   @id @default(uuid())
  sku         String   @unique
  title       String
  description String?
  brand       String?
  price       Float
  cost        Float?
  inventory   Int      @default(0)
  images      String   // JSON array of URLs
  
  // Product specifics
  category    String?
  weight      Float?
  dimensions  String?  // JSON: {length, width, height}
  specifics   String?  // JSON: item-specific attributes
  
  // Metadata
  sourceUrl   String?  // Original eBay URL if scraped
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  listings    Listing[]
  orderItems  OrderItem[]
  
  @@index([sku])
  @@index([createdAt])
}

// ============================================
// LISTINGS - Marketplace Listings
// ============================================
model Listing {
  id              String   @id @default(uuid())
  productId       String
  channel         String   // ebay, etsy, woocommerce
  channelListingId String? // External ID from marketplace
  
  // Listing details
  title           String
  description     String?
  price           Float
  quantity        Int
  status          String   @default("draft") // draft, active, paused, ended
  
  // Channel-specific data
  listingUrl      String?
  offerId         String?
  metadata        String?  // JSON: channel-specific fields
  
  // Timestamps
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([channel, channelListingId])
  @@index([productId])
  @@index([status])
  @@index([channel])
}

// ============================================
// ORDERS - Unified Order Management
// ============================================
model Order {
  id              String   @id @default(uuid())
  orderNumber     String   @unique
  channel         String   // ebay, etsy, woocommerce
  channelOrderId  String
  
  // Customer info
  customerName    String
  customerEmail   String?
  shippingAddress String   // JSON: address object
  
  // Order totals
  subtotal        Float
  shippingCost    Float    @default(0)
  tax             Float    @default(0)
  total           Float
  
  // Order status
  status          String   @default("new") // new, processing, shipped, completed, cancelled
  trackingNumber  String?
  
  // Timestamps
  orderDate       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  items           OrderItem[]
  shipment        Shipment?
  
  @@index([channel])
  @@index([status])
  @@index([orderDate])
}

// ============================================
// ORDER ITEMS - Products in Orders
// ============================================
model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String?
  
  // Item details
  sku         String
  title       String
  quantity    Int
  price       Float
  
  // Relations
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  
  @@index([orderId])
  @@index([productId])
}

// ============================================
// SHIPMENTS - Shipping Labels
// ============================================
model Shipment {
  id              String   @id @default(uuid())
  orderId         String   @unique
  
  // Shipping details
  carrier         String   // usps, ups, fedex, canadapost
  service         String   // priority, express, standard
  trackingNumber  String
  labelPath       String?  // Local file path to label PDF
  
  // Costs
  cost            Float?
  
  // Timestamps
  createdAt       DateTime @default(now())
  
  // Relations
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@index([trackingNumber])
}

// ============================================
// CAMPAIGNS - Marketing & Promotions
// ============================================
model Campaign {
  id            String   @id @default(uuid())
  name          String
  channel       String?  // ebay, etsy, all
  
  // Campaign details
  discountType  String   // percentage, fixed, bogo
  discountValue Float
  products      String?  // JSON array of product IDs
  
  // Scheduling
  startDate     DateTime?
  endDate       DateTime?
  status        String   @default("scheduled") // scheduled, active, completed, cancelled
  
  // Metadata
  metadata      String?  // JSON: SEO assets, tracking URLs
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([status])
  @@index([channel])
}

// ============================================
// SCRAPED DATA - Competitor Analysis
// ============================================
model ScrapedListing {
  id              String   @id @default(uuid())
  sourceUrl       String   @unique
  itemNumber      String
  
  // Listing data
  title           String
  price           Float
  description     String?
  images          String?  // JSON array
  
  // Seller info
  seller          String?
  location        String?
  
  // Market data
  availableQty    String?
  soldCount       Int?
  watchers        Int?
  
  // Analysis
  keywords        String?  // JSON array
  priceHistory    String?  // JSON: price tracking
  
  // Mapping
  mappedToSku     String?  // Link to our product SKU
  
  // Timestamps
  scrapedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([mappedToSku])
  @@index([scrapedAt])
}

// ============================================
// LOGS - System Activity Logs
// ============================================
model ActivityLog {
  id          String   @id @default(uuid())
  action      String   // scrape, publish, order_sync, etc
  module      String   // ebay, etsy, scraper, etc
  status      String   // success, error, warning
  message     String?
  metadata    String?  // JSON: additional data
  
  // Timestamps
  createdAt   DateTime @default(now())
  
  @@index([action])
  @@index([module])
  @@index([createdAt])
}
