PORT=3001
BACKEND_PORT=4001

# Optional: force puppeteer to use a local browser binary
PUPPETEER_EXECUTABLE_PATH=

# eBay Sandbox API credentials
EBAY_ENV=sandbox
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_DEV_ID=
EBAY_MARKETPLACE_ID=EBAY_US

# eBay OAuth User Token (requires user authorization)
# Visit /api/ebay-auth-url to get authorization URL
# After authorization, exchange code for refresh token
EBAY_REDIRECT_URI=http://localhost:3001/api/ebay-callback
EBAY_REFRESH_TOKEN=

# eBay listing configuration
# You must create these policies in eBay Seller Hub first:
# - Fulfillment/Shipping Policy
# - Payment Policy  
# - Return Policy
# Then get the policy IDs and add them here
EBAY_CATEGORY_ID=
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_LOCATION_KEY=
